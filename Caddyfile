{
    email {$CADDY_EMAIL}
}

{$DOMAIN_NAME} {
    # SSE endpoints require streaming — disable response buffering.
    @sse path /api/v1/*/events
    handle @sse {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            flush_interval -1
        }
    }

    # All other traffic
    handle {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}
