# =============================================================================
# WDIAG — Where Did It All Go
# Copy this file to .env and fill in values. Never commit .env.
# =============================================================================

# Active compose profiles.
# bundled-proxy: includes Caddy reverse proxy (enabled by default)
# ollama: includes a local Ollama instance for AI features (optional)
COMPOSE_PROFILES=bundled-proxy

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=wdiag
POSTGRES_PASSWORD=changeme-use-a-real-password
POSTGRES_DB=wdiag

# Override if using an external Postgres (also disable the postgres service):
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Master encryption key for field-level encryption of sensitive data.
# Generate with: openssl rand -hex 32
MASTER_KEY=changeme-generate-with-openssl-rand-hex-32

LOG_LEVEL=INFO
DEBUG=false

# Comma-separated list of allowed CORS origins (frontend dev server):
ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Caddy reverse proxy (used when COMPOSE_PROFILES includes bundled-proxy)
# -----------------------------------------------------------------------------
DOMAIN_NAME=localhost
CADDY_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Backup (optional — local volume always used; S3 is additional)
# -----------------------------------------------------------------------------
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
# BACKUP_S3_BUCKET=my-wdiag-backups
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# Generate with: openssl rand -hex 32
# BACKUP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# OpenTelemetry collector endpoint (leave unset to disable tracing):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
